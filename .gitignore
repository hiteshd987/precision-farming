# ── YOLO / Ultralytics ────────────────────────────────────────────────
# Ignore all model weights by default...
models/*.pt
models/*.onnx
models/*.engine
models/*.torchscript
# ...except the fine-tuned production weights
!models/aerial_weeds.pt

# Training runs output
runs/

# ── Reports / Database ────────────────────────────────────────────────
# Ignore all reports by default...
reports/*.jsonl
reports/*.json
# ...except the master report database
!reports/argo_report.jsonl

# ── Datasets ──────────────────────────────────────────────────────────
!datasets/
datasets/drone_images/
